# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# News API Keys (get free at newsapi.org)
NEWS_API_KEY=your_newsapi_key

# CryptoPanic (free, no key needed)
CRYPTOPANIC_API_KEY=

# Shelby Protocol
SHELBY_API_KEY=your_shelby_api_key

# Alert Configuration
ALERT_INTERVAL_MINUTES=5
MIN_IMPACT_SCORE=0.5
MAX_ALERTS_PER_HOUR=20

# Keyword filter config (JSON array of filters, overrides default filters)
# FILTER_CONFIG=[{"keywords": ["solana"], "exclude": ["scam"], "label": "Solana"}]

# Monitoring
MONITORED_TOKENS=bitcoin,ethereum,solana,binance,cardano,polygon,avalanche-2,chainlink,uniswap,aave
MONITORED_KEYWORDS=SEC,ETF,FDA,approval,launch,hack,exploit,regulation,ban,delist

# News Sources (enabled/disabled)
ENABLE_NEWSAPI=true
ENABLE_CRYPTOPANIC=true
ENABLE_REDDIT=true
ENABLE_COINGECKO_NEWS=true

# Shelby Storage
SHELBY_ENABLED=true
SHELBY_BLOB_RETENTION=never  # never, 7d, 30d, 90d
